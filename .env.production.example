# GridTokenX Production Environment Template
# ---------------------------------------------------------
# MANDATORY: Copy this to .env and replace all placeholders
# with secure, production-grade values.
# All secrets (JWT_SECRET, ENCRYPTION_SECRET, etc.) must come from Vault.
# See .env.secrets.example for the full secrets reference.
# ---------------------------------------------------------

# General
TZ=UTC
ENVIRONMENT=production

# =============================================================================
# Persistence Layer (7000-range)
# =============================================================================

# PostgreSQL (Production: Use a managed DB if possible, or robust volume backups)
POSTGRES_DB=gridtokenx
POSTGRES_USER=gridtokenx_admin
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_PRIMARY_PORT=7001
POSTGRES_REPLICA_PORT=7002
MAX_CONNECTIONS=100

# Redis Cache
REDIS_PRIMARY_PORT=7010
REDIS_REPLICA_PORT=7011
REDIS_MAX_CONNECTIONS=50

# InfluxDB (Time-series data)
INFLUXDB_URL=http://influxdb:7020
INFLUXDB_PORT=7020
INFLUXDB_ORG=gridtokenx
INFLUXDB_BUCKET=energy_readings
INFLUXDB_TOKEN=CHANGE_ME_INFLUX_TOKEN

# ClickHouse (Analytics)
CLICKHOUSE_PORT=7030

# =============================================================================
# API Gateway & User-Facing Layer (4000-range)
# =============================================================================

# API Gateway Security — use 'openssl rand -base64 32' to generate secrets
APIGATEWAY_PORT=4000
SERVER_HOST=0.0.0.0
JWT_SECRET=CHANGE_ME_SECURE_JWT_SECRET
JWT_EXPIRATION=86400
API_KEY_SECRET=CHANGE_ME_SECURE_API_KEY_SECRET
HMAC_SECRET=CHANGE_ME_SECURE_HMAC_SECRET
ENCRYPTION_SECRET=CHANGE_ME_SECURE_WALLET_ENCRYPTION_KEY

# CORS
CORS_ALLOWED_ORIGINS=https://app.gridtokenx.com
SECURE_COOKIES=true

# =============================================================================
# Internal Service Mesh — gRPC (5000-range)
# =============================================================================

IAM_GRPC_PORT=5010
TRADING_GRPC_PORT=5020
ORACLE_GRPC_PORT=5030
CHAIN_BRIDGE_GRPC_PORT=5040

# =============================================================================
# Blockchain Layer (8000-range)
# =============================================================================

SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://your-production-rpc-provider.com
SOLANA_RPC_PORT=8001
SOLANA_WS_URL=wss://your-production-rpc-provider.com
SOLANA_WS_PORT=8002
TOKENIZATION_ENABLE_REAL_BLOCKCHAIN=true

# Program IDs (Update for Mainnet)
REGISTRY_PROGRAM_ID=CVS6pz2qdEmjusHCmiwe2R22KVrSoGubdEy5d766KooN
ENERGY_TOKEN_PROGRAM_ID=HaT3koMseafcCB9aUQUCrSLMDfN1km7Xik9UhZSG9UV6
TRADING_PROGRAM_ID=8gHn9oeYcUQgNrMi8fNYGyMCKJTMwM6K413f41AANFt4
GOVERNANCE_PROGRAM_ID=GAZQm4bHUyNhSYrAq5noBohXcTaf6dKZNDKju8499e6w
ENERGY_TOKEN_MINT=HseYbxxw92N8JeC4AAu4eN4XdTpzr5jCMVMbFTaJXLFp

# =============================================================================
# Frontend Applications (11000-range)
# =============================================================================

TRADING_UI_PORT=11001
EXPLORER_PORT=11002
PORTAL_PORT=11003

# =============================================================================
# Observability (6000-range)
# =============================================================================

PROMETHEUS_PORT=6001
GRAFANA_PORT=6002
LOKI_PORT=6003
TEMPO_PORT=6004
SIGNOZ_PORT=6005
OTEL_COLLECTOR_PORT=6006

ENABLE_METRICS=true
ENABLE_TRACING=true
PROMETHEUS_METRICS_ENABLED=true
METRICS_PORT=6010

# =============================================================================
# Messaging Layer (9000-range)
# =============================================================================

KAFKA_CMD_PORT=9001
KAFKA_MARKET_PORT=9002
KAFKA_AUDIT_PORT=9003
KAFKA_BOOTSTRAP_SERVERS=kafka:9001
KAFKA_ENABLED=true

RABBITMQ_PORT=9030
RABBITMQ_MGMT_PORT=9031
RABBITMQ_ENABLED=true

# =============================================================================
# Infrastructure (13000-range)
# =============================================================================

VAULT_PORT=13001

# Email Service (Replace Mailpit with Real Provider)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM_ADDRESS=noreply@gridtokenx.com
ENABLE_EMAIL_VERIFICATION=true

# =============================================================================
# Admin & Debug (10000-range) — NEVER expose to public internet
# =============================================================================

IAM_ADMIN_PORT=10010
TRADING_ADMIN_PORT=10020
ORACLE_ADMIN_PORT=10030
CHAIN_BRIDGE_ADMIN_PORT=10040

IAM_HEALTH_PORT=10200
TRADING_HEALTH_PORT=10210
ORACLE_HEALTH_PORT=10220
CHAIN_BRIDGE_HEALTH_PORT=10230

# =============================================================================
# Feature Flags
# =============================================================================

RATE_LIMIT_ENABLED=true
