# =============================================================================
# GridTokenX — Production Environment Template
# =============================================================================
# MANDATORY: Copy this to .env and replace all placeholders with secure values.
# All secrets must come from Vault or a secure CI/CD secret manager.
# -----------------------------------------------------------------------------

# ---------------------------------------------------------
# 1. System & General
# ---------------------------------------------------------
TZ=UTC
ENVIRONMENT=production
NODE_ENV=production
DEBUG=false
RUST_LOG=warn
LOG_LEVEL=info
LOG_FORMAT=json

# ---------------------------------------------------------
# 2. Ports & Gateways
# ---------------------------------------------------------
# Primary Gateway
PORT=80
SERVER_PORT=8080
APIGATEWAY_PORT=8080
SERVER_HOST=0.0.0.0

# External Gateways (Ports in Docker)
APISIX_PORT=80
ENVOY_PORT=443

# ---------------------------------------------------------
# 3. Persistence Layer
# ---------------------------------------------------------
# PostgreSQL
POSTGRES_DB=gridtokenx
POSTGRES_USER=gridtokenx_admin
POSTGRES_PRIMARY_PORT=5432
POSTGRES_REPLICA_PORT=5432

# Redis
REDIS_PRIMARY_PORT=6379
REDIS_REPLICA_PORT=6379

# InfluxDB
INFLUXDB_PORT=8086
INFLUXDB_ORG=gridtokenx
INFLUXDB_BUCKET=energy_readings

# Internal Connection URLs (Production Service Mesh)
DATABASE_URL=postgresql://${POSTGRES_USER}:CHANGE_ME_SECURE_PASSWORD@postgres:5432/${POSTGRES_DB}
TRADING_DATABASE_URL=${DATABASE_URL}
REDIS_URL=redis://redis:6379
INFLUXDB_URL=http://influxdb:8086

# ---------------------------------------------------------
# 4. Messaging & Event Bus
# ---------------------------------------------------------
# Kafka
KAFKA_CMD_PORT=9092
KAFKA_MARKET_PORT=9092
KAFKA_AUDIT_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092,kafka-2:9092
KAFKA_ENABLED=true

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_DEFAULT_USER=gridtokenx_prod
RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:CHANGE_ME_SECURE_PASSWORD@rabbitmq:5672
RABBITMQ_ENABLED=true

# ---------------------------------------------------------
# 5. Microservices — HTTP/gRPC
# ---------------------------------------------------------
# IAM Service
IAM_HTTP_PORT=8080
IAM_GRPC_PORT=5010

# Trading Service
TRADING_HTTP_PORT=8080
TRADING_GRPC_PORT=5020

# Aggregator Bridge
IOT_GATEWAY_PORT=4010
AGGREGATOR_BRIDGE_HTTP_PORT=4010
ORACLE_GRPC_PORT=5030

# Noti Service
NOTI_HTTP_PORT=8080
NOTI_GRPC_PORT=5060

# Chain Bridge
CHAIN_BRIDGE_GRPC_PORT=5040
CHAIN_BRIDGE_INSECURE=false

# ---------------------------------------------------------
# 6. Frontend & Simulator
# ---------------------------------------------------------
# Frontend Apps (Port mappings in LB/Ingress)
TRADING_UI_PORT=3000
EXPLORER_PORT=3000

# Public URLs
NEXT_PUBLIC_API_URL=https://api.gridtokenx.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_PYTH_PRICE_SERVICE_URL=https://hermes.pyth.network

# ---------------------------------------------------------
# 7. Blockchain Layer (Solana)
# ---------------------------------------------------------
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Program IDs (Update for Mainnet)
REGISTRY_PROGRAM_ID=CHANGE_ME_PROD_PROGRAM_ID
TRADING_PROGRAM_ID=CHANGE_ME_PROD_PROGRAM_ID
ORACLE_PROGRAM_ID=CHANGE_ME_PROD_PROGRAM_ID
GOVERNANCE_PROGRAM_ID=CHANGE_ME_PROD_PROGRAM_ID
ENERGY_TOKEN_MINT=CHANGE_ME_PROD_MINT
CURRENCY_TOKEN_MINT=CHANGE_ME_PROD_MINT

# Wallets & Keys
AUTHORITY_WALLET_PATH=/app/secrets/authority-wallet.json
FEE_COLLECTOR_WALLET=CHANGE_ME_PROD_WALLET
AGGREGATOR_BRIDGE_PUBLIC_KEY=CHANGE_ME_PROD_PUBLIC_KEY

# ---------------------------------------------------------
# 8. Observability & Monitoring
# ---------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
TEMPO_PORT=3200

ENABLE_METRICS=true

# ---------------------------------------------------------
# 9. App Logic & Constraints
# ---------------------------------------------------------
MAX_CONNECTIONS=100
MIN_CONNECTIONS=10
REQUEST_TIMEOUT=60
CACHE_TTL_DEFAULT=3600
RATE_LIMIT_ENABLED=true

# ---------------------------------------------------------
# 10. Secrets & Sensitive Data (Vault Managed)
# ---------------------------------------------------------
# Placeholder values — actual secrets must be injected at runtime
JWT_SECRET=CHANGE_ME_SECURE_JWT_SECRET
ENCRYPTION_SECRET=CHANGE_ME_SECURE_WALLET_ENCRYPTION_KEY
API_KEY_SECRET=CHANGE_ME_SECURE_API_KEY_SECRET
HMAC_SECRET=CHANGE_ME_SECURE_HMAC_SECRET
ENGINEERING_API_KEY=CHANGE_ME_SECURE_API_KEY

AES_KEY_BASE64=CHANGE_ME_SECURE_AES_KEY
PAYER_PRIVATE_KEY=CHANGE_ME_SECURE_SOLANA_KEY

POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
RABBITMQ_DEFAULT_PASS=CHANGE_ME_SECURE_PASSWORD
INFLUXDB_TOKEN=CHANGE_ME_SECURE_TOKEN

BINANCE_API_KEY=CHANGE_ME_SECURE_BINANCE_KEY
BINANCE_SECRET_KEY=CHANGE_ME_SECURE_BINANCE_SECRET
NEXT_PUBLIC_MAPBOX_TOKEN=CHANGE_ME_PROD_MAPBOX_TOKEN

# Email/SMTP
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME_SMTP_USER
SMTP_PASSWORD=CHANGE_ME_SMTP_PASS
EMAIL_FROM_ADDRESS=noreply@gridtokenx.com
