# Secure (locked-down) telemetry profile — layered over .env by `just secure-up`.
#
#   docker compose --env-file .env --env-file secure.env up -d
#
# Flips on every layer of the smart-meter telemetry hardening at once (the
# intended production posture). Server-auth TLS is already on by the compose
# defaults; this adds mutual TLS, payload encryption, key rotation, and the
# ingest lockdown. Prereqs: `just gen-certs` (certs) + `just provision-kek`
# (Vault KEK) — `just secure-up` runs the KEK step for you.
#
# Flag -> hardening phase:
#   IOT_GATEWAY_TLS_CLIENT_CA        Phase 6  mTLS: bridge verifies the sim's client cert
#   SMARTMETER_ENCRYPT_ENABLED       Phase 2  per-meter AES-256-GCM payload + replay counter
#   SMARTMETER_KEY_ROTATION_ENABLED  Phase 3  Vault-KEK-wrapped rotating keys (raw key never at rest)
#   SMARTMETER_KEY_ROTATION_INTERVAL_S Phase 5 background auto-rotation cadence (seconds)
#   AGGREGATOR_REQUIRE_SECURE        Phase 4  reject every ingest bypass (no plaintext/unsigned/downgrade)

# mTLS: require + verify the sim client cert against the dev CA.
IOT_GATEWAY_TLS_CLIENT_CA=/app/infra/certs/ca.crt

# Payload encryption + key rotation (needs Vault + the KEK).
SMARTMETER_ENCRYPT_ENABLED=true
SMARTMETER_KEY_ROTATION_ENABLED=true
SMARTMETER_KEY_ROTATION_INTERVAL_S=300

# Lockdown: only authenticated, encrypted frames are accepted.
AGGREGATOR_REQUIRE_SECURE=true

# At-rest: encrypt Redis stream payloads (full register set opaque at rest).
AGGREGATOR_ENCRYPT_STREAMS=true
