# ==============================================================================
# GridTokenX — Secrets Reference
# ==============================================================================
# This file documents ALL secrets used across the platform.
# NEVER put real values here. This file is safe to commit.
#
# In production: all secrets are injected by Vault Agent into the process
# environment. In local dev: set these in your local .env (gitignored).
#
# Vault paths follow the convention: secret/gridtokenx/<service>#<field>
# Retrieve manually: vault kv get -field=<field> secret/gridtokenx/<service>
# ==============================================================================

# =============================================================================
# IAM Service — secret/gridtokenx/iam
# =============================================================================

# JWT signing key (min 32 chars). Used to sign and verify all JWTs.
JWT_SECRET=

# AES-256-GCM master key for encrypting Ed25519 wallet keypairs at rest.
ENCRYPTION_SECRET=

# API key signing secret for scoped API key generation.
API_KEY_SECRET=

# HMAC secret for request signature verification.
HMAC_SECRET=

# =============================================================================
# Trading Service — secret/gridtokenx/trading
# =============================================================================

# AES-256 key (base64-encoded, 32 bytes) for encrypting trading-layer data.
AES_KEY_BASE64=

# Solana payer keypair as a JSON byte array [u8; 64].
# This is the fee-payer for on-chain transactions submitted by the trading service.
PAYER_PRIVATE_KEY=

# =============================================================================
# Edge Gateway — secret/gridtokenx/edge-gateway
# =============================================================================

# Raspberry Pi SSH credentials for remote deployment via CI/CD.
# Never store in .env files — use CI/CD secrets (GitHub Actions, GitLab CI, etc.)
PI_USER=
PI_HOST=
PI_PASS=

# =============================================================================
# Infrastructure — secret/gridtokenx/infra
# =============================================================================

# InfluxDB admin token (generated during InfluxDB setup).
INFLUXDB_TOKEN=

# PostgreSQL passwords
POSTGRES_PASSWORD=
RABBITMQ_DEFAULT_PASS=

# SMTP credentials (production email provider, e.g. AWS SES)
SMTP_USERNAME=
SMTP_PASSWORD=

# =============================================================================
# Oracle Bridge — secret/gridtokenx/oracle-bridge
# =============================================================================

# Comma-separated API keys for IoT device authentication (ESP32, EV chargers, etc.)
# Generate with: openssl rand -hex 16
GRIDTOKENX_API_KEYS=

# =============================================================================
# How to inject secrets via Vault Agent (production)
# =============================================================================
#
# 1. Store a secret:
#    vault kv put secret/gridtokenx/iam jwt_secret="$(openssl rand -base64 48)"
#
# 2. Vault Agent template (agent-config.hcl):
#    template {
#      contents = "JWT_SECRET={{ with secret \"secret/gridtokenx/iam\" }}{{ .Data.data.jwt_secret }}{{ end }}"
#      destination = "/run/secrets/iam.env"
#    }
#
# 3. Service reads from injected file:
#    ExecStart=/usr/bin/env-file /run/secrets/iam.env /usr/local/bin/gridtokenx-iam-service
#
# =============================================================================
# How to set secrets for local development
# =============================================================================
#
# Copy the relevant keys into your local .env (gitignored) and fill in dev values:
#
#   JWT_SECRET=dev-jwt-secret-key-minimum-32-characters-long-for-development-2025
#   ENCRYPTION_SECRET=dev-encryption-secret-key-32-chars-minimum-for-wallet-encryption
#   AES_KEY_BASE64=<base64 of 32 random bytes: openssl rand -base64 32>
#   PAYER_PRIVATE_KEY=<solana-keygen output as JSON byte array>
#
