# ==============================================================================
# GridTokenX — Secrets Reference
# ==============================================================================
# This file documents ALL secrets used across the platform.
# NEVER put real values here. This file is safe to commit.
# ------------------------------------------------------------------------------

# 1. IAM Service — secret/gridtokenx/iam
# ---------------------------------------------------------
# JWT signing key (min 32 chars).
JWT_SECRET=

# AES-256-GCM master key for encrypting wallet keypairs.
ENCRYPTION_SECRET=
OWS_VAULT_PATH=/var/lib/gridtokenx/ows-vault

# API key signing secret.
API_KEY_SECRET=

# HMAC secret for request signature verification.
HMAC_SECRET=

# Engineering department API key.
ENGINEERING_API_KEY=


# 2. Trading Service — secret/gridtokenx/trading
# ---------------------------------------------------------
# AES-256 key (base64-encoded, 32 bytes).
AES_KEY_BASE64=

# Solana payer keypair as a JSON byte array [u8; 64].
PAYER_PRIVATE_KEY=

# Binance API credentials.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=


# 3. Infrastructure — secret/gridtokenx/infra
# ---------------------------------------------------------
# PostgreSQL / RabbitMQ / InfluxDB passwords.
POSTGRES_PASSWORD=
RABBITMQ_DEFAULT_PASS=
INFLUXDB_TOKEN=

# SMTP credentials (production provider).
SMTP_USERNAME=
SMTP_PASSWORD=


# 4. Aggregator Bridge — secret/gridtokenx/aggregator-bridge
# ---------------------------------------------------------
# Comma-separated API keys for IoT device authentication.
GRIDTOKENX_API_KEYS=


# 5. External Integration — secret/gridtokenx/external
# ---------------------------------------------------------
# Mapbox public token for geographic visualizations.
NEXT_PUBLIC_MAPBOX_TOKEN=
