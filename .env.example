# =============================================================================
# GridTokenX — Unified Environment Configuration
# =============================================================================

# ---------------------------------------------------------
# 1. System & General
# ---------------------------------------------------------
TZ=UTC
ENVIRONMENT=development
# External SNTP time source for NTP-corrected wall-clock (gridtokenx_telemetry::time).
# Comma-separated host:port, tried in order; first to answer wins. Point at an
# internal NTP for prod/air-gapped deploys. Set NTP_DISABLE=1 (per service) to skip
# sync entirely and use the OS clock. Degrades safely to OS clock if unreachable.
NTP_SERVERS=time.cloudflare.com:123,time.google.com:123
NODE_ENV=development
DEBUG=true
RUST_LOG=info
LOG_LEVEL=info
LOG_FORMAT=json

# ---------------------------------------------------------
# 2. Ports & Gateways (4000-range)
# ---------------------------------------------------------
# Primary Gateway / API Orchestrator
PORT=4000
SERVER_PORT=${PORT}
APIGATEWAY_PORT=${PORT}
SERVER_HOST=0.0.0.0

# External Gateways
APISIX_PORT=4001

# ---------------------------------------------------------
# 3. Persistence Layer (7000-range)
# ---------------------------------------------------------
# PostgreSQL
POSTGRES_DB=gridtokenx
POSTGRES_USER=gridtokenx_user
POSTGRES_PRIMARY_PORT=7001
# Postgres primary commit durability. Unset → safe default `on` (prod/CI).
# Set `off` ONLY in local dev for write throughput (~0.6s data-loss window on
# hard crash; tolerated via Outbox + chain-as-truth, see docs/RELIABILITY.md).
PG_SYNCHRONOUS_COMMIT=off

# PgDog (Rust pooler/load balancer, runs alongside PgBouncer on 6432)
PGDOG_PORT=7003

# Redis
REDIS_PRIMARY_PORT=7010

# Internal Connection URLs (Local Dev)
DATABASE_URL=postgresql://${POSTGRES_USER}:gridtokenx_password@localhost:${POSTGRES_PRIMARY_PORT}/${POSTGRES_DB}
TRADING_DATABASE_URL=${DATABASE_URL}
REDIS_URL=redis://localhost:${REDIS_PRIMARY_PORT}

# ---------------------------------------------------------
# 4. Messaging & Event Bus (9000-range)
# ---------------------------------------------------------
# Kafka
KAFKA_CMD_PORT=9001
KAFKA_MARKET_PORT=9002
KAFKA_AUDIT_PORT=9003
KAFKA_BOOTSTRAP_SERVERS=gridtokenx-kafka-cmd.orb.local:9001
KAFKA_ENABLED=true

# RabbitMQ
RABBITMQ_PORT=9030
RABBITMQ_MGMT_PORT=9031
RABBITMQ_DEFAULT_USER=gridtokenx
RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:rabbitmq_secret_2025@localhost:${RABBITMQ_PORT}
RABBITMQ_ENABLED=true

# ---------------------------------------------------------
# 5. Microservices — HTTP/gRPC (4000/5000-range)
# ---------------------------------------------------------
# IAM Service
IAM_HTTP_PORT=4010
IAM_GRPC_PORT=5010
IAM_ADMIN_PORT=10010
IAM_HEALTH_PORT=10200

# Trading Service
TRADING_HTTP_PORT=4020
TRADING_GRPC_PORT=5020
TRADING_ADMIN_PORT=10020
TRADING_HEALTH_PORT=10210

# Aggregator Bridge
IOT_GATEWAY_PORT=4030
AGGREGATOR_BRIDGE_HTTP_PORT=4030
ORACLE_GRPC_PORT=5030
ORACLE_ADMIN_PORT=10030
ORACLE_HEALTH_PORT=10220

# Meter Service (distinct from Noti's 4060 to avoid host-port collision)
METER_SERVICE_PORT=4062

# Noti Service
NOTI_HTTP_PORT=4060
NOTI_GRPC_PORT=5060

# Chain Bridge
CHAIN_BRIDGE_GRPC_PORT=5040
CHAIN_BRIDGE_ADMIN_PORT=10040
CHAIN_BRIDGE_HEALTH_PORT=10230
# mTLS is the default — run `just gen-certs` once to create infra/certs/.
# Set true only to bypass mTLS in dev (grants Admin role to all callers).
CHAIN_BRIDGE_INSECURE=false
# NATS envelope signing enforcement. Services sign chain.tx.* envelopes with
# their mTLS client key; the bridge verifies cert→CA→SPIFFE SAN→signature.
# Contract: non-dev (staging/prod) MUST set this true — a forged chain.tx.submit
# envelope is otherwise accepted (log-only). This local-dev default is the
# EXPLICIT escape hatch: false so version skew across submodule pins can never
# halt the write path. Flip to true once the bridge's nats_auth_unsigned metric
# is zero across the fleet (see docs/plans/meter-to-solana-hardening.md rollout).
CHAIN_BRIDGE_REQUIRE_SIGNED_NATS=false
# Path B generation mints (Aggregator Bridge → NATS → Chain Bridge). The publisher
# MUST present all three envelope-identity vars below or the bridge consumer drops
# the request silently (publisher sees only a submit_transaction timeout):
#   CHAIN_BRIDGE_CLIENT_CERT / CHAIN_BRIDGE_CLIENT_KEY → infra/certs/clients/<svc>.{crt,key}
#   CHAIN_BRIDGE_SERVICE_IDENTITY → spiffe://gridtokenx.th/prod/<svc> (must match cert SAN)
# scripts/cmd/start.sh wires these for the native Aggregator Bridge launch.
MINT_VIA_CHAIN_BRIDGE=true
NATS_URL=nats://localhost:9020
CHAIN_BRIDGE_URL=http://localhost:5040

# Agent Trade
AGENT_TRADE_HTTP_PORT=4050
AGENT_TRADE_DATABASE_URL=sqlite:///app/data/agent.db

# ---------------------------------------------------------
# 6. Frontend & Simulator (11000/12000-range)
# ---------------------------------------------------------
# Frontend Apps
TRADING_UI_PORT=11001
EXPLORER_PORT=11002

# Smart Meter Simulator
SMARTMETER_PORT=12010
SMARTMETER_SIMULATOR_PORT=12010
SIMULATOR_URL=http://127.0.0.1:${SMARTMETER_PORT}

# Public URLs
NEXT_PUBLIC_API_URL=http://gridtokenx-apisix.orb.local:9080
NEXT_PUBLIC_API_BASE_URL=http://gridtokenx-apisix.orb.local:9080
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PYTH_PRICE_SERVICE_URL=https://hermes.pyth.network

# ---------------------------------------------------------
# 7. Blockchain Layer (Solana)
# ---------------------------------------------------------
SOLANA_CLUSTER=localnet
SOLANA_RPC_URL=http://localhost:8899
SOLANA_RPC_PORT=8001
SOLANA_WS_PORT=8002

