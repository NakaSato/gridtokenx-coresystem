# General
TZ=UTC

# =============================================================================
# Persistence Layer (7000-range)
# =============================================================================

# PostgreSQL
POSTGRES_DB=gridtokenx
POSTGRES_USER=gridtokenx_user
POSTGRES_PASSWORD=gridtokenx_password
POSTGRES_PRIMARY_PORT=7001
POSTGRES_REPLICA_PORT=7002

# Connection URLs (for services that need full URL)
DATABASE_URL=postgresql://gridtokenx_user:gridtokenx_password@localhost:7001/gridtokenx
TRADING_DATABASE_URL=postgresql://gridtokenx_user:gridtokenx_password@localhost:7001/gridtokenx
REDIS_URL=redis://localhost:7010

# Redis
REDIS_PRIMARY_PORT=7010
REDIS_REPLICA_PORT=7011

# InfluxDB
INFLUXDB_PORT=7020
INFLUXDB_USER=gridtokenx_user
INFLUXDB_PASSWORD=gridtokenx_password
INFLUXDB_ORG=gridtokenx
INFLUXDB_BUCKET=energy_readings
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_URL=http://localhost:7020

# ClickHouse
CLICKHOUSE_PORT=7030

# =============================================================================
# API Gateway & User-Facing Layer (4000-range)
# =============================================================================

# API Services (Lead Orchestrator)
APIGATEWAY_PORT=4000
PORT=4000
SERVER_HOST=0.0.0.0
SERVER_PORT=4000

# APISIX Gateway (User-facing)
APISIX_PORT=4001

# Envoy Gateway (IoT/mTLS)
ENVOY_PORT=4002

# Oracle Bridge IoT Gateway
IOT_GATEWAY_PORT=4030
ORACLE_BRIDGE_API_GATEWAY_URL=http://host.docker.internal:4000
ORACLE_BRIDGE_HTTP_PORT=4030

# Trading Service HTTP (metrics)
TRADING_HTTP_PORT=4020

# IAM Service HTTP
IAM_HTTP_PORT=4010

# =============================================================================
# Internal Service Mesh — gRPC (5000-range)
# =============================================================================

# IAM Service gRPC
IAM_GRPC_PORT=5010

# Trading Service gRPC (primary)
TRADING_GRPC_PORT=5020

# Oracle Bridge gRPC
ORACLE_GRPC_PORT=5030

# Chain Bridge gRPC
CHAIN_BRIDGE_GRPC_PORT=5040

# OTEL Collector
OTEL_COLLECTOR_GRPC_PORT=6006
OTEL_COLLECTOR_HTTP_PORT=6007

# cAdvisor
CADVISOR_PORT=6010

# =============================================================================
# Application Configuration
# =============================================================================

ENVIRONMENT=development
RUST_LOG=info
LOG_LEVEL=info
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true
TEST_MODE=false

# Database / Redis Connection Pools
MAX_CONNECTIONS=50
MIN_CONNECTIONS=5
DATABASE_MAX_CONNECTIONS=50
DATABASE_MIN_CONNECTIONS=5
REDIS_POOL_SIZE=20
REDIS_MAX_CONNECTIONS=20
REDIS_CONNECTION_TIMEOUT=5
REDIS_COMMAND_TIMEOUT=3
REQUEST_TIMEOUT=30

# Smart Meter Simulator Integration
SIMULATOR_URL=http://127.0.0.1:12010

