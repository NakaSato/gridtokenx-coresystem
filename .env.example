# ---------------------------------------------------------
PROMETHEUS_PORT=6001
GRAFANA_PORT=6002
LOKI_PORT=6003
TEMPO_PORT=6004
METRICS_PORT=9090

ENABLE_METRICS=true

# ---------------------------------------------------------
# 9. App Logic & Constraints
# ---------------------------------------------------------
MAX_CONNECTIONS=50
MIN_CONNECTIONS=5
REQUEST_TIMEOUT=30
CACHE_TTL_DEFAULT=3600
RATE_LIMIT_ENABLED=true

# ---------------------------------------------------------
# 10. Secrets & Sensitive Data (Consolidated)
# ---------------------------------------------------------
# IAM Secrets
JWT_SECRET=dev-jwt-secret-key-minimum-32-characters-long-for-development-2025
ENCRYPTION_SECRET=dev-encryption-secret-key-32-chars-minimum-for-wallet-encryption
