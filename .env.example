SOLANA_TRADING_PROGRAM_ID=CnWDEUhTvSixeLSyViWgAnnu9YouBAYVGcrrFm1s9WcX
SOLANA_ORACLE_PROGRAM_ID=64Vgos61STZ8pW9NnHi2iGtXMTQr7NqBoMorK6Zg8RJU
SOLANA_GOVERNANCE_PROGRAM_ID=FokVuBSPXP11aeL7VZWd8n8aVAhWqVpyPZETToSxdvTS
SOLANA_ENERGY_TOKEN_PROGRAM_ID=6FZKcVKCLFSNLMxypFJGU4K14xUBnxNW9VAuKGhmqjGX
ENERGY_TOKEN_MINT=7Gina6oKXgd8aEeBGUJnrVb6CKd8srVExiEZWdA4hwaE
CURRENCY_TOKEN_MINT=8BGFtQLRaY9Nh5BGUwjJvdeXEsscCgJAi5zTgALk1Vg5
