{
  "schemaVersion": 39,
  "title": "GridTokenX Mint Pipeline",
  "uid": "gridtokenx-mint-pipeline",
  "tags": ["gridtokenx", "mint", "aggregator", "chain-bridge"],
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Mint failure rate (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.05 }, { "color": "red", "value": 0.25 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(blockchain_operations_total{operation=\"nats_consumer_mint\",success=\"false\"}[5m])) / clamp_min(sum(rate(blockchain_operations_total{operation=\"nats_consumer_mint\"}[5m])), 1)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Aggregator mints (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(aggregator_mint_total)" }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Grid frequency (Hz)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "rothz", "min": 49.5, "max": 50.5, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 49.9 }, { "color": "red", "value": 50.1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg(aggregator_grid_frequency_hz)" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "NATS envelope auth (5m rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(blockchain_operations_total{operation=\"nats_auth_verified\",success=\"true\"}[5m]))" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Chain Bridge mint operations (ops/s by outcome)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (success) (rate(blockchain_operations_total{operation=\"nats_consumer_mint\"}[5m]))", "legendFormat": "success={{success}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Mint processing latency (chain-bridge, ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "blockchain_operation_duration_ms{operation=\"nats_consumer_mint\",quantile=\"0.5\"}", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "blockchain_operation_duration_ms{operation=\"nats_consumer_mint\",quantile=\"0.95\"}", "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "blockchain_operation_duration_ms{operation=\"nats_consumer_mint\",quantile=\"0.99\"}", "legendFormat": "p99" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Aggregator mint rate (mints/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 40 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(aggregator_mint_total[5m]))", "legendFormat": "aggregator mints/s" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Aggregator mint outcomes (by outcome/reason, 5m rate)",
      "description": "Breaks down every aggregator mint decision. queued=surplus sent to chain.tx.mint; no_surplus=window under threshold; failed(mint_err)=submit rejected; skipped(no_wallet|resolve_err)=owner/wallet unresolved; skipped(in_flight)=dedup guard. A rising skipped/failed line pinpoints a stall (e.g. REC-validator drift, missing owner wallet) that the bare mint total hides.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }, "color": { "mode": "palette-classic" } }, "overrides": [ { "matcher": { "id": "byRegexp", "options": ".*failed.*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }, { "matcher": { "id": "byRegexp", "options": "no_surplus.*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] } ] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (outcome, reason) (rate(aggregator_mint_total[5m]))", "legendFormat": "{{outcome}}/{{reason}}" }
      ]
    }
  ]
}
